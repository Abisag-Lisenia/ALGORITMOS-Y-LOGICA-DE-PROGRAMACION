#include <iostream>
#include <iomanip>

using namespace std;

int main() {
    int numEst, numDias, alim, inst, coord;
    float cHospDia, pTrans, cTrans, cHosp, cAlim = 0, subtotal, desc = 0, total, cPers;

    cout << "--- PLANIFICADOR DE VIAJE ESTUDIANTIL ---" << endl;
    cout << "Numero de estudiantes: "; cin >> numEst;
    cout << "Numero de dias: "; cin >> numDias;
    cout << "Costo hospedaje/dia (persona): "; cin >> cHospDia;
    cout << "Incluye alimentacion (1:Si, 0:No): "; cin >> alim;
    cout << "Descuento institucional (1:Si, 0:No): "; cin >> inst;
    cout << "Lleva coordinador (1:Si, 0:No): "; cin >> coord;

    // Lógica de Transporte
    pTrans = (numEst > 15) ? 15 : 20; // Operador ternario para simplificar
    cTrans = (coord == 1) ? (numEst - 1) * pTrans : numEst * pTrans;

    // Lógica de Hospedaje
    cHosp = numEst * cHospDia * numDias;
    if (numDias > 3) cHosp *= 0.90;

    // Lógica de Alimentación
    if (alim == 1) cAlim = numEst * 10 * numDias;

    subtotal = cTrans + cHosp + cAlim;

    // Descuento institucional
    if (subtotal > 500 && inst == 1) desc = subtotal * 0.05;

    total = subtotal - desc;
    cPers = total / numEst;

    cout << fixed << setprecision(2);
    cout << "\n======= DESGLOSE DE COSTOS =======" << endl;
    cout << "Transporte     : $" << cTrans << endl;
    cout << "Hospedaje      : $" << cHosp << endl;
    cout << "Alimentacion   : $" << cAlim << endl;
    cout << "Descuento      : $" << desc << endl;
    cout << "----------------------------------" << endl;
    cout << "TOTAL VIAJE    : $" << total << endl;
    cout << "COSTO INDIVIDUAL: $" << cPers << endl;

    if (cPers > 150) cout << "ESTADO: Viaje NO recomendable" << endl;
    else cout << "ESTADO: Viaje Recomendable" << endl;

    return 0;
}
